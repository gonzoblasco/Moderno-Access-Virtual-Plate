# Moderno Access Virtual Plate - Environment Configuration
# Copy this file to .env and customize for your setup

# Server Configuration
PORT=8080
BOARD_TYPE=TNG PRO

# Security Settings
# MODE=unauthorized para deshabilitar auth (solo desarrollo local)
# MODE=online o MODE=authorized para requerir autenticación
MODE=authorized
BOARD_USER=admin
BOARD_PASS=<generar-contrasena-segura>

# Hardware Simulation
SERIAL_NUMBER=TNG20260506
RELAYS=2
LATENCY_MS=0

# Cloud Integration (opcional)
# WEBHOOK_URL para reportar eventos a tu API
WEBHOOK_URL=http://localhost:3000/api/webhook
# MODERNO_API_URL=https://access.moderno.com.ar
